import React from 'react';
import { View, Text, ScrollView } from 'react-native';

export const OutputPanel = ({ logs, status }: { logs: string[], status: string }) => (
  <ScrollView style={{ backgroundColor: '#1e1e1e', padding: 10, flex: 1 }}>
    {logs.map((log, index) => (
      <Text key={index} style={{ color: status === 'error' ? '#ff5555' : '#50fa7b', fontFamily: 'monospace' }}>
        {'> ' + log}
      </Text>
    ))}
  </ScrollView>
);
