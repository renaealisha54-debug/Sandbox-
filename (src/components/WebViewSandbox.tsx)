import React, { forwardRef, useImperativeHandle, useRef } from 'react';
import { WebView } from 'react-native-webview';

export const WebViewSandbox = forwardRef(({ onMessage }: any, ref) => {
  const webViewRef = useRef<WebView>(null);

  useImperativeHandle(ref, () => ({
    runCode: (code: string) => {
      const wrappedCode = `
        (function() {
          const originalLog = console.log;
          console.log = (...args) => {
            window.ReactNativeWebView.postMessage(JSON.stringify({ type: 'LOG', data: args.join(' ') }));
            originalLog.apply(console, args);
          };
          try {
            const result = eval(${JSON.stringify(code)});
            window.ReactNativeWebView.postMessage(JSON.stringify({ type: 'SUCCESS', data: String(result) }));
          } catch (e) {
            window.ReactNativeWebView.postMessage(JSON.stringify({ type: 'ERROR', data: e.message }));
          }
        })();
      `;
      webViewRef.current?.injectJavaScript(wrappedCode);
    }
  }));

  return (
    <WebView
      ref={webViewRef}
      style={{ display: 'none' }}
      onMessage={(event) => onMessage(event.nativeEvent.data)}
      source={{ html: '<html><body></body></html>' }}
    />
  );
});
